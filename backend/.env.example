# Copy this file to .env and fill in at least one provider API key.
#
# Task 07.1 — Agent OS supports four selectable model providers. A provider is
# available in the UI only if its key is set here; missing-key providers show
# as disabled. Claude is the preferred default when ANTHROPIC_API_KEY is set.

ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Optional — override the default model per provider without touching code.
# AGENT_OS_CLAUDE_MODEL=claude-sonnet-4-20250514
# AGENT_OS_OPENAI_MODEL=gpt-4o
# AGENT_OS_GEMINI_MODEL=gemini-1.5-flash
# AGENT_OS_DEEPSEEK_MODEL=deepseek-chat
