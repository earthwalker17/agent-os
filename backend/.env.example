# Copy this file to .env and fill in at least one provider API key.
#
# Provider Registry 2.0 — Agent OS supports six selectable model providers, each
# with a per-provider list of selectable models. A provider is available in the
# UI only if its key is set here; missing-key providers show as disabled. Claude
# is the preferred default when ANTHROPIC_API_KEY is set.

ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ZHIPUAI_API_KEY=

# Accepted aliases (used only if the primary above is unset):
#   GEMINI_API_KEY  -> Gemini      (alias of GOOGLE_API_KEY)
#   KIMI_API_KEY    -> Kimi        (alias of MOONSHOT_API_KEY)
#   ZAI_API_KEY     -> GLM / Z.ai  (alias of ZHIPUAI_API_KEY)

# Optional — override the default model per provider without touching code.
# (Defaults are the latest API-available model per provider as of 2026-06.)
# AGENT_OS_CLAUDE_MODEL=claude-opus-4-8
# AGENT_OS_OPENAI_MODEL=gpt-5.5
# AGENT_OS_GEMINI_MODEL=gemini-3.5-flash
# AGENT_OS_DEEPSEEK_MODEL=deepseek-v4-flash
# AGENT_OS_KIMI_MODEL=kimi-k2.6
# AGENT_OS_GLM_MODEL=glm-5.2

# Optional — override the OpenAI-compatible chat endpoint (e.g. China-region
# hosts for Kimi / GLM, or a gateway / proxy).
# AGENT_OS_KIMI_BASE_URL=https://api.moonshot.cn/v1/chat/completions
# AGENT_OS_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# AGENT_OS_OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# AGENT_OS_DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# Phase 7 — Project Ops / GitHub connector.
# A GitHub Personal Access Token (classic `repo` scope, or a fine-grained token
# with Contents + Pull requests read/write) is the *global* fallback used for
# push + PR creation. Per-project tokens can also be set from the UI connector
# (stored in the gitignored credentials/ store, which overrides this). The token
# is injected only into git's environment at push time and never appears in
# argv, commits, logs, events, memory, or the UI.
# GITHUB_TOKEN=
# Accepted aliases (used only if GITHUB_TOKEN is unset): AGENT_OS_GITHUB_TOKEN, GH_TOKEN
